<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="420.0" prefWidth="580.0"
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="org.uniquindio.proyectofinalcodigo.viewController.LoginViewController">

    <VBox alignment="CENTER" spacing="14.0"
          AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <padding><Insets top="30" bottom="30" left="60" right="60"/></padding>

        <Label text="TECH-PARK UQ" style="-fx-font-size:28px; -fx-font-weight:bold;"/>
        <Label text="Sistema de Gestion del Parque" style="-fx-font-size:13px;"/>

        <Separator/>

        <Label text="Cedula:" style="-fx-font-weight:bold;"/>
        <TextField fx:id="txtCedula" promptText="Ingrese su cedula" prefWidth="260.0"/>

        <Label fx:id="lblError" text="" style="-fx-text-fill:red; -fx-font-size:11px;" wrapText="true"/>

        <Label text="Seleccione su rol:" style="-fx-font-weight:bold;"/>

        <HBox spacing="12.0" alignment="CENTER">
            <Button text="Visitante" prefWidth="130" prefHeight="40"
                    style="-fx-background-color:#2e7d32; -fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:13px;"
                    onAction="#LoginVisitante"/>
            <Button text="Operador" prefWidth="130" prefHeight="40"
                    style="-fx-background-color:#1565c0; -fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:13px;"
                    onAction="#LoginOperador"/>
            <Button text="Administrador" prefWidth="130" prefHeight="40"
                    style="-fx-background-color:#b71c1c; -fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:13px;"
                    onAction="#LoginAdmin"/>
        </HBox>

        <Separator/>

        <Label text="¿No tiene cuenta de visitante?" style="-fx-font-size:11px;"/>
        <Button text="Registrarse como Visitante" prefWidth="200"
                style="-fx-font-size:11px;"
                onAction="#RegistrarVisitante"/>

        <Label text="Cuentas de prueba: V001 | V002 | OP001 | OP002 | AD001"
               style="-fx-font-size:10px; -fx-text-fill:#666666;" wrapText="true"/>
    </VBox>
</AnchorPane>
